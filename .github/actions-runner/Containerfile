# CEF VAAPI GitHub Actions runner image.
#
# This image contains Arch Linux build dependencies for the CEF PKGBUILD and
# the GitHub Actions runner binary. Secrets are supplied only at runtime via
# the container runtime environment; do not bake tokens into this image.

FROM archlinux:latest

ARG RUNNER_VERSION=2.334.0
ARG RUNNER_UID=1000
ARG RUNNER_GID=1000

# Install CEF runtime/build dependencies plus GitHub Actions tooling.
RUN pacman -Syu --noconfirm && \
    pacman -S --noconfirm --needed \
      alsa-lib \
      at-spi2-core \
      base-devel \
      clang \
      compiler-rt \
      curl \
      dbus \
      fakeroot \
      git \
      github-cli \
      gn \
      gperf \
      java-runtime-headless \
      jq \
      libdrm \
      libffi \
      libpulse \
      libva \
      libxcomposite \
      libxdamage \
      libxkbcommon \
      libxrandr \
      libxtst \
      lld \
      mesa \
      ninja \
      nodejs \
      npm \
      nss \
      pango \
      pipewire \
      python \
      python-httplib2 \
      python-pyparsing \
      python-six \
      rsync \
      rust \
      rust-bindgen && \
    pacman -Scc --noconfirm && \
    rm -rf /var/cache/pacman/pkg/*

# Match the host user UID/GID when building the image for bind-mounted state.
RUN groupadd -g "${RUNNER_GID}" runner && \
    useradd -m -u "${RUNNER_UID}" -g "${RUNNER_GID}" -d /home/runner -s /bin/bash runner && \
    mkdir -p /runner /cache /opt/actions-runner && \
    chown -R runner:runner /runner /cache /opt/actions-runner

# Install the GitHub Actions runner into /opt. Entrypoint copies it into the
# persistent /runner volume on first start so runner registration survives
# container/image recreation.
RUN cd /opt/actions-runner && \
    curl -sL "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/actions-runner-linux-x64-${RUNNER_VERSION}.tar.gz" \
      -o runner.tar.gz && \
    echo "048024cd2c848eb6f14d5646d56c13a4def2ae7ee3ad12122bee960c56f3d271  runner.tar.gz" | sha256sum -c && \
    tar xzf runner.tar.gz && \
    rm runner.tar.gz && \
    chown -R runner:runner /opt/actions-runner

COPY --chmod=755 entrypoint.sh /entrypoint.sh

USER runner
WORKDIR /runner

ENV RUNNER_REPO_URL=https://github.com/bnema/cef-vaapi
ENV RUNNER_NAME=cef-vaapi-builder
ENV RUNNER_LABELS=self-hosted,cef-builder,x64,linux
ENV RUNNER_HOME=/runner

ENTRYPOINT ["/entrypoint.sh"]
